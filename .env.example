HOST_NAME=example.com

# Optional: Discord webhook URL for server error alarms (unhandled exceptions, 5xx errors, client JS errors)
# DISCORD_ALARM_WEBHOOK=https://discord.com/api/webhooks/...

ADMIN_PASSWORD=qwert12345

# Optional: set server timezone (defaults to America/Los_Angeles)
# APP_TIMEZONE=UTC

# Optional: log verbosity. One of debug | info | warn | error.
# Default: info (or error when NODE_ENV=test). See src/server/lib/logger.ts.
# LOG_LEVEL=info

PLAID_CLIENT_ID=000000000
PLAID_SECRET_PRODUCTION=000000000
PLAID_SECRET_DEVELOPMENT=000000000
PLAID_SECRET_SANDBOX=000000000

POLYGON_API_KEY=000000000

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=budget